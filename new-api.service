# File path: /etc/systemd/system/new-api.service
# sudo systemctl daemon-reload
# sudo systemctl start new-api
# sudo systemctl enable new-api
# sudo systemctl status new-api
[Unit]
Description=newapi
After=network.target

[Service]
User=root 
WorkingDirectory=/root/new-api
ExecStart=/path/to/new-api/new-api --port 3000 --log-dir /root/new-api/logs  
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
